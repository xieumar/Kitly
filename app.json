{
  "expo": {
    "name": "kitly",
    "slug": "kitly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kitly-icon.png",
    "scheme": "kitly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080D16",
        "foregroundImage": "./assets/images/kitly-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.zainab_i.kitly"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/kitly-icon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2bdfec4-c62b-4035-acb8-5c2f9e0992f2"
      }
    }
  }
}
